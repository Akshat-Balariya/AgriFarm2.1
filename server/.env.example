# Flask & Backend Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/agrigo_db
SQLALCHEMY_DATABASE_URI=postgresql://user:password@localhost:5432/agrigo_db

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_ID=gemini-2.5-flash

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Firebase Configuration
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@agrigo.com

# Node.js Chatbot Configuration
NODE_ENV=production
PORT=3000

# API Endpoints
API_BASE_URL=http://localhost:5000
CHAT_API_BASE_URL=http://localhost:3000

# File Upload Configuration
MAX_UPLOAD_SIZE=52428800
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png

# Logging
LOG_LEVEL=INFO

# Feature Flags
ENABLE_CELERY_TASKS=True
ENABLE_WEBSOCKET=True
ENABLE_CACHE=True

