# ==================================================
# Website/UI .gitignore
# Covers Vite, React, TypeScript, Node.js
# ==================================================

# ==================================================
# Node Modules & Dependencies
# ==================================================
node_modules/
npm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
bun.lockb
pnpm-lock.yaml

# ==================================================
# Build Output
# ==================================================
dist/
.vite/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/

# ==================================================
# Environment & Secrets (CRITICAL!)
# ==================================================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.*.js

# ==================================================
# IDE & Editor
# ==================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-workspace
.c9/
.tern-port

# ==================================================
# Logs
# ==================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ==================================================
# OS Specific
# ==================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ==================================================
# Testing
# ==================================================
coverage/
.nyc_output/
.mocha_output/

# ==================================================
# TypeScript
# ==================================================
*.tsbuildinfo
dist-types/

# ==================================================
# Keep These (Important!)
# ==================================================
# DO NOT IGNORE:
# - .env.example (safe template)
# - vite.config.ts (build config)
# - tsconfig.json (TypeScript config)
# - package.json (dependencies)
# - src/ (all source code)
# - public/ (assets)

